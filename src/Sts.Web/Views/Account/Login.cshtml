@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-2">Login</h1>
                <p class="text-secondary mb-4">Sign in with your STS email and password.</p>
                
                <form asp-action="Login" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid"
                         role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" autocomplete="email" class="form-control"/>
                        <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" type="password" autocomplete="current-password" class="form-control"/>
                        <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
