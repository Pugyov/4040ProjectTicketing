@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-page">
    <div class="panel">
        <h1>Login</h1>
        <p class="panel__subtitle">Sign in with your STS email and password.</p>

        <form asp-action="Login" method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div class="form-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" autocomplete="current-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="button button--full">Login</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
