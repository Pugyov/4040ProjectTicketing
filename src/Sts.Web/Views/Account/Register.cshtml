@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-page">
    <div class="panel">
        <h1>Register</h1>
        <p class="panel__subtitle">Create your STS account to access ticket workflows.</p>

        <form asp-action="Register" method="post" class="form-grid">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div class="form-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" autocomplete="new-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <div class="form-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>

            <div class="form-field">
                <label asp-for="Name"></label>
                <input asp-for="Name" autocomplete="name" />
                <span asp-validation-for="Name"></span>
            </div>

            <div class="form-field">
                <label asp-for="Team"></label>
                <select asp-for="Team">
                    <option value="">-- Select Team --</option>
                    <option value="Development">Development</option>
                    <option value="Support">Support</option>
                    <option value="Sales">Sales</option>
                </select>
                <span asp-validation-for="Team"></span>
            </div>

            <button type="submit" class="button button--full">Register</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
