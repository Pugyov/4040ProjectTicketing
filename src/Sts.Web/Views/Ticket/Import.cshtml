@model ImportTicketsViewModel
@{
    ViewData["Title"] = "Import Tickets";
}

<section class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
                    <div>
                        <p class="text-uppercase text-primary-emphasis small fw-semibold mb-2">Bulk Ticket Upload</p>
                        <h1 class="h3 mb-1">Import Tickets</h1>
                        <p class="text-secondary mb-0">Upload a JSON file that matches the required schema. Imported tickets are assigned to your team automatically.</p>
                    </div>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary text-nowrap flex-shrink-0 align-self-md-center">Back Home</a>
                </div>

                @if (ViewData["ImportErrors"] is IReadOnlyList<string> importErrors && importErrors.Count > 0)
                {
                    <div class="alert alert-danger" role="alert">
                        @foreach (var error in importErrors)
                        {
                            <div>@error</div>
                        }
                    </div>
                }

                <div class="alert alert-light border">
                    <p class="fw-semibold mb-2">Expected JSON format</p>
                    <pre class="mb-0"><code>{
  "tickets": [
    {
      "subject": "Example ticket",
      "description": "Optional description",
      "status": "New"
    }
  ]
}</code></pre>
                </div>

                <form method="post" enctype="multipart/form-data" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-valid" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="File" class="form-label">JSON File</label>
                        <input asp-for="File" class="form-control" accept=".json,application/json" />
                        <span asp-validation-for="File" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Import Tickets</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
